{
  "version": "1.0.0",
  "registry": { "backend": "json" },
  "services": [
    {
      "serviceId": "aurora-service",
      "repo": "aurora",
      "root": "../aurora/aurora-service",
      "graphRef": "../aurora/aurora-service/.understand-anything/knowledge-graph.json",
      "domainRef": "../aurora/aurora-service/.understand-anything/domain-graph.json",
      "http": { "basePath": "/aurora", "gatewayPrefix": "" },
      "mq": {
        "consumerBaseClass": "AbstractRocketMqHandler",
        "producerClass": "MqSendService",
        "topics": {
          "byProp": { "mq.rocket-mq.producerTopic_dispatchAnalysisNoticed": "DISPATCH_ANALYSIS_NOTICED" },
          "byHandler": {
            "com.hk.simba.pre.mq.consumer.PreDispatchAnalysisNoticedHandler": "DISPATCH_ANALYSIS_NOTICED",
            "com.hk.simba.aurora.mq.ServiceWorkOrderDesignatedHandler": "WORKORDER_DESIGNATED"
          }
        }
      },
      "protocols": { "dubbo": true, "http": true, "mq": true }
    },
    {
      "serviceId": "backend-aurora",
      "repo": "aurora",
      "root": "../aurora/backend-aurora",
      "graphRef": "../aurora/backend-aurora/.understand-anything/knowledge-graph.json",
      "domainRef": "../aurora/backend-aurora/.understand-anything/domain-graph.json",
      "http": { "basePath": "/backend-aurora", "gatewayPrefix": "" },
      "protocols": { "dubbo": true, "http": true, "mq": true }
    },
    {
      "serviceId": "aurora-web",
      "repo": "aurora",
      "root": "../aurora/aurora-web",
      "graphRef": "../aurora/aurora-web/.understand-anything/knowledge-graph.json",
      "domainRef": "../aurora/aurora-web/.understand-anything/domain-graph.json",
      "http": { "hostMap": { "aurora": "/aurora", "workorder": "/workorder" } },
      "protocols": { "dubbo": false, "http": true, "mq": false }
    },
    {
      "serviceId": "workorder-service",
      "repo": "workorder",
      "root": "../workorder/workorder-service",
      "graphRef": "../workorder/workorder-service/.understand-anything/knowledge-graph.json",
      "domainRef": "../workorder/workorder-service/.understand-anything/domain-graph.json",
      "http": { "basePath": "/workorder", "gatewayPrefix": "" },
      "mq": {
        "topics": {
          "byProp": { "mq.rocket-mq.producerTopic_workOrderDesignated": "WORKORDER_DESIGNATED" }
        }
      },
      "protocols": { "dubbo": true, "http": true, "mq": true }
    }
  ]
}
